<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="16dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="巻"
            android:textSize="30sp"
            android:textColor="@color/accent"
            android:fontFamily="serif"
            android:paddingEnd="10dp"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MangaCast"
                android:textSize="20sp"
                android:textColor="@color/text"
                android:textStyle="bold"
                android:letterSpacing="0.05"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="CHARACTER LOOKUP"
                android:textSize="9sp"
                android:textColor="@color/textMuted"
                android:letterSpacing="0.14"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⇪ SHARE TARGET"
            android:textSize="9sp"
            android:textColor="@color/accent"
            android:background="@drawable/badge_share"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"/>
    </LinearLayout>

    <View
        android:layout_width="120dp"
        android:layout_height="1dp"
        android:background="@color/accent"/>

    <LinearLayout
        android:id="@+id/sharedPill"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface2"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">

        <View
            android:layout_width="6dp"
            android:layout_height="6dp"
            android:background="@drawable/dot_accent"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SHARED"
            android:textSize="9sp"
            android:textColor="@color/accent"
            android:letterSpacing="0.1"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/sharedTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="12sp"
            android:textColor="@color/text"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface"
        android:padding="12dp"
        android:orientation="horizontal">

        <EditText
            android:id="@+id/searchInput"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@drawable/bg_input"
            android:hint="Type manga title…"
            android:textColorHint="@color/textMuted"
            android:textColor="@color/text"
            android:textSize="13sp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:maxLines="1"
            android:fontFamily="monospace"/>

        <Button
            android:id="@+id/searchBtn"
            android:layout_width="64dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="@drawable/bg_btn_accent"
            android:text="GO"
            android:textColor="@android:color/white"
            android:textSize="11sp"
            android:letterSpacing="0.06"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/stateIdle"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📖"
                android:textSize="48sp"
                android:alpha="0.3"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HOW TO USE"
                android:textSize="18sp"
                android:textColor="@color/textDim"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="20dp"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="1. Open a manga in TachiyomiSY\n\n2. Tap the Share button on the manga info page\n\n3. Select MangaCast from the share sheet\n\n4. Characters load automatically\n\nOr just type a title above to search manually."
                android:textSize="13sp"
                android:textColor="@color/textDim"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stateLoading"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:visibility="gone">

            <ProgressBar
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:indeterminateTint="@color/accent"
                android:layout_marginBottom="16dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOOKING UP CHARACTERS…"
                android:textSize="11sp"
                android:textColor="@color/textDim"
                android:letterSpacing="0.08"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/stateError"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="28dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="40sp"
                android:textColor="@color/accent"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/errorText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Could not find manga."
                android:textSize="13sp"
                android:textColor="@color/textDim"
                android:gravity="center"
                android:lineSpacingExtra="4dp"/>
        </LinearLayout>

        <LinearLayout
            android:id="@+id/resultsPanel"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:padding="14dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/mangaCover"
                    android:layout_width="60dp"
                    android:layout_height="86dp"
                    android:scaleType="centerCrop"
                    android:background="@color/surface2"
                    android:layout_marginEnd="14dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/mangaTitleEn"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textColor="@color/text"
                        android:textStyle="bold"
                        android:maxLines="2"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/mangaTitleJp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="12sp"
                        android:textColor="@color/textDim"
                        android:fontFamily="serif"
                        android:layout_marginTop="4dp"
                        android:maxLines="1"
                        android:ellipsize="end"/>

                    <TextView
                        android:id="@+id/mangaMeta"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textSize="10sp"
                        android:textColor="@color/gold"
                        android:layout_marginTop="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/surface"
                android:scrollbars="none"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="10dp"
                android:paddingBottom="10dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/chipAll"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="All"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/chipMain"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Main"
                        android:textSize="11sp"
                        android:layout_marginEnd="8dp"/>

                    <Button
                        android:id="@+id/chipSupporting"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="wrap_content"
                        android:layout_height="36dp"
                        android:text="Supporting"
                        android:textSize="11sp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/border"/>

            <LinearLayout
                android:id="@+id/descLoadingBar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:background="@color/surface2"
                android:visibility="gone">

                <ProgressBar
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:indeterminateTint="@color/textDim"
                    android:layout_marginEnd="8dp"/>

                <TextView
                    android:id="@+id/descLoadingText"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="10sp"
                    android:textColor="@color/textDim"
                    android:letterSpacing="0.05"
                    android:text="Loading descriptions…"/>
            </LinearLayout>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/charRecycler"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:paddingBottom="16dp"/>
        </LinearLayout>

    </FrameLayout>

</LinearLayout>
